# Environment template for the read-only MLB/NBA recommendation engine.
#
# Copy this file to `.env` in the repository root and fill in your own values.
# `.env` is git-ignored and is the ONLY environment file the application loads.
# Never commit real credentials -- this template must stay empty.

# The Odds API key (https://the-odds-api.com). Held as a SecretStr; never printed.
ODDS_API_KEY=

# Kalshi public REST. In production read-only mode this is the only accepted URL.
# No Kalshi authentication, API key, or private key is used.
KALSHI_PUBLIC_REST_URL=https://external-api.kalshi.com/trade-api/v2
KALSHI_ENVIRONMENT=production

# Local historical corpus (SQLite). Relative paths resolve against the
# repository root. The file is git-ignored and is created by:
#     python -m sports_quant db-init
DATABASE_PATH=data/corpus.db

# Read-only safety invariants. Startup refuses to run unless these exact values
# hold -- this project only ever produces recommendations.
READ_ONLY_MODE=true
ORDER_SUBMISSION_ENABLED=false
PAPER_TRADING=false
LIVE_TRADING=false
MANUAL_LIVE_ARMING=false

# --- Phase D (official data) -- PLANNED, not yet used by any code path. --------
# Blank placeholders only; fill locally in .env if/when Phase D is implemented.
# See PHASE_D_PROVIDER_DECISIONS.md. Held as SecretStr; never printed or stored.
#
# NBA schedule/results/box scores via balldontlie (https://www.balldontlie.io).
# The ONLY key the Phase D MVP requires. Free tier issues a key.
NBA_DATA_API_KEY=
#
# These selected Phase D providers need NO key, so they have NO variable:
#   MLB StatsAPI (statsapi.mlb.com), NBA Stats API (stats.nba.com, headers only),
#   Open-Meteo free tier, NWS (api.weather.gov, User-Agent only),
#   Chadwick register (static file), NBA injury report (public PDF).
#
# Optional -- leave blank for the no-paid MVP path:
# Keyed weather provider (only if chosen instead of Open-Meteo/NWS).
WEATHER_API_KEY=
# Professional (paid, betting-licensed) providers for both sports.
SPORTRADAR_MLB_API_KEY=
SPORTRADAR_NBA_API_KEY=
