# Secrets: never commit a real environment file or any private key material.
# `.env.example` is the only committed environment template.
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.pfx

# Virtual environments
venv/
.venv/

# Python build / bytecode artifacts
__pycache__/
*.py[cod]

# Tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Coverage
.coverage
htmlcov/

# Local data corpus (SQLite). Built by `python -m sports_quant db-init`;
# never committed -- it is derived data, and it grows without bound.
data/
*.db
*.db-wal
*.db-shm
